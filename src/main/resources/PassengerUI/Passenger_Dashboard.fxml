<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="org.BOGO.BOGOUIController" styleClass="root">
    <HBox spacing="24">
        <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>
        <StackPane fx:id="map_box" HBox.hgrow="ALWAYS">
            <fx:include source="../MapView_ALL.fxml"/>
        </StackPane>
        <ScrollPane prefWidth="340" fitToWidth="true">
            <VBox fx:id="box_active_bookings" spacing="14">
                <VBox spacing="8" styleClass="neon-card" onMouseClicked="#showCancelRidePane">
                    <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
                    <Label text="Booking #BG-1102" styleClass="subheader-text"/>
                    <Label text="Liberty Market to Model Town" styleClass="body-text"/>
                    <Label text="ETA 12 min | Rs. 220" styleClass="muted-text"/>
                </VBox>
                <VBox spacing="8" styleClass="neon-card" onMouseClicked="#showCancelRidePane">
                    <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
                    <Label text="Booking #BG-1108" styleClass="subheader-text"/>
                    <Label text="Gulberg Main to Railway Station" styleClass="body-text"/>
                    <Label text="ETA 18 min | Rs. 310" styleClass="muted-text"/>
                </VBox>
            </VBox>
        </ScrollPane>
    </HBox>
    <!-- TODO: BACKEND - Send cancellation request; trigger fading notification. -->
    <VBox fx:id="pane_cancel_ride" visible="false" alignment="CENTER" maxWidth="360" spacing="16" styleClass="neon-card">
        <padding><Insets top="28" right="28" bottom="28" left="28"/></padding>
        <Label text="Cancel Ride?" styleClass="subheader-text"/>
        <Button fx:id="btn_cancel_ride" text="CANCEL RIDE" onAction="#hideCancelRidePane" maxWidth="Infinity" styleClass="button-red"/>
        <Button fx:id="btn_go_back" text="GO BACK" onAction="#hideCancelRidePane" maxWidth="Infinity" styleClass="button-purple"/>
    </VBox>
</StackPane>
